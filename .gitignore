.DS_Store

# Swift Package Manager (Phase 1.0+)
swift/.build/
swift/Package.resolved
swift/.swiftpm/
swift/dist/
*.swiftmodule
*.dSYM

# macOS Finder/Spotlight Duplikat-Artefakte ("filename 2.ext")
* [0-9].*

